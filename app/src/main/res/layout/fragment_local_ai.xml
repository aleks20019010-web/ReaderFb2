<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Action Bar Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_panel"
            android:padding="16dp"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Меню"
                app:tint="@color/icon_tint" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btnMenu"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:text="Локальный ИИ (Vikhr 0.5B)"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Capabilities Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ Офлайн ИИ: Vikhr 0.5B Instruct"
                            android:textColor="@color/accent"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Локальная компактная нейросеть Vikhr 0.5B Instruct (~400 МБ) работает 100% автономно на вашем устройстве без облака, интернета и API-ключей. Оптимизирована для устройств с ограниченной ОЗУ."
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• 👥 Глубокий анализ персонажей по 5 пунктам"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• 📖 Краткое содержание книг и выжимка темы (3-5 предложений)"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• 🔍 Пояснение устаревших слов и терминов в контексте (RAG)"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• 🌍 Двусторонний контекстный переводчик слов"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Model Management Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardModelManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛠️ Статус модели Vikhr 0.5B"
                            android:textColor="@color/accent"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/modelStatusLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Статус:"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/modelStatusValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/modelStatusLabel"
                                android:layout_marginStart="8dp"
                                android:text="Проверка модели..."
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Download Progress Layout -->
                        <LinearLayout
                            android:id="@+id/layoutDownloadProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/txtDownloadStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Скачивание Vikhr 0.5B... 0%"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:layout_marginBottom="4dp" />

                            <ProgressBar
                                android:id="@+id/progressDownload"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="10dp"
                                android:progressTint="@color/accent"
                                android:progressBackgroundTint="@color/divider"
                                android:layout_marginBottom="8dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btnCancelDownload"
                                    style="@style/Widget.App.Button"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="44dp"
                                    android:text="Отмена"
                                    android:textSize="13sp"
                                    android:layout_marginEnd="4dp" />

                                <Button
                                    android:id="@+id/btnRetryDownload"
                                    style="@style/Widget.App.Button"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="44dp"
                                    android:text="Повторить"
                                    android:textSize="13sp"
                                    android:visibility="gone"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Loading Indicator in Memory -->
                        <LinearLayout
                            android:id="@+id/layoutMemoryLoad"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/txtMemoryLoadStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Загрузка модели в ОЗУ... (5-15 сек)"
                                android:textColor="@color/accent"
                                android:textSize="14sp"
                                android:layout_marginBottom="6dp" />

                            <ProgressBar
                                android:id="@+id/pbMemoryLoad"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:indeterminate="true"
                                android:indeterminateTint="@color/accent" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRequirementNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Требования к устройству: Android 7.0+, 2+ ГБ ОЗУ, 1 ГБ свободного места на диске."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"
                            android:textAlignment="center" />

                        <!-- Action Buttons -->
                        <Button
                            android:id="@+id/btnDownloadModel"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Скачать Vikhr 0.5B (~400 МБ)"
                            android:backgroundTint="@color/btn_bg"
                            android:textColor="@color/btn_text"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnInitModel"
                            style="@style/Widget.App.Button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Загрузить модель в память"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnUnloadModel"
                            style="@style/Widget.App.Button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Выгрузить из ОЗУ (освободить память)"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnUploadCustomRules"
                            style="@style/Widget.App.Button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Импортировать правила/словарь (.json)"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            app:cornerRadius="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnClearCache"
                                style="@style/Widget.App.Button"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="48dp"
                                android:text="Очистить кэш"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp" />

                            <Button
                                android:id="@+id/btnDeleteModel"
                                style="@style/Widget.App.Button"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="48dp"
                                android:text="Удалить модель"
                                android:textColor="#FF5252"
                                android:textSize="13sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Interactive Test Console Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTestConsole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖 Интерактивная консоль Vikhr 0.5B"
                            android:textColor="@color/accent"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Задайте вопрос по книгам, терминам или стилистике произведения для проверки локальной модели:"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Preset Prompts -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/chipPhilosophy"
                                    style="@style/Widget.App.Button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Проанализируй персонажа"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="8dp" />

                                <Button
                                    android:id="@+id/chipAuthor"
                                    style="@style/Widget.App.Button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Краткое содержание"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="8dp" />

                                <Button
                                    android:id="@+id/chipPlot"
                                    style="@style/Widget.App.Button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Поясни термин"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </HorizontalScrollView>

                        <!-- Input Field -->
                        <EditText
                            android:id="@+id/etTestPrompt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Введите вопрос для Vikhr 0.5B..."
                            android:textColorHint="@color/text_secondary"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_edittext_rounded"
                            android:padding="12dp"
                            android:minLines="2"
                            android:gravity="top"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Execute Button -->
                        <Button
                            android:id="@+id/btnRunTest"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Спросить Vikhr 0.5B"
                            android:backgroundTint="@color/btn_bg"
                            android:textColor="@color/btn_text"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"
                            app:cornerRadius="12dp" />

                        <!-- Response Area -->
                        <LinearLayout
                            android:id="@+id/layoutTestResponse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:background="@drawable/bg_glass_panel"
                            android:padding="12dp">

                            <ProgressBar
                                android:id="@+id/pbTestProgress"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginBottom="8dp"
                                android:indeterminateTint="@color/accent" />

                            <TextView
                                android:id="@+id/tvTestResponse"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:lineSpacingMultiplier="1.1" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
