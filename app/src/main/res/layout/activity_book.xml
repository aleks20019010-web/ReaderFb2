<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <View
        android:id="@+id/ambientGlowView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <com.nightread.app.ui.customlayout.CustomReaderPageView
        android:id="@+id/bookReaderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
    <View
        android:id="@+id/touchInterceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/ivBookCoverPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="220 вольт"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmark" />

        <ImageButton
            android:id="@+id/btnChapters"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmarks_list" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings_24dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Стр. 10 из 226" />
        
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="2dp"
            android:maxHeight="2dp"
            android:thumbTint="#000000"
            android:progressTint="#000000"
            android:progressBackgroundTint="#CCCCCC" />
    </LinearLayout>

    <View
        android:id="@+id/amberFilterOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <View
        android:id="@+id/extraDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <!-- Brightness Indicator -->
    <TextView
        android:id="@+id/tvBrightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_brightness"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:visibility="gone"
        android:text="☀ 75%" />

    <!-- Warmth Indicator -->
    <TextView
        android:id="@+id/tvWarmth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_brightness"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:visibility="gone"
        android:text="🌡 30%" />

    <!-- Book Reader Loading / Splash Overlay -->
    <FrameLayout
        android:id="@+id/reader_splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <!-- Starry Background matching the Main Splash Screen -->
        <com.nightread.app.ui.StarryNightView
            android:id="@+id/reader_splash_starry_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_reader_splash_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N I G H T R E A D"
                android:textColor="#FFE3A8"
                android:textSize="20sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.35" />

            <TextView
                android:id="@+id/tv_reader_splash_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="АТМОСФЕРА ПОЛУНОЧИ"
                android:textColor="#8B7CA2"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.25" />

            <TextView
                android:id="@+id/tv_reader_splash_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Настройка ночного уюта..."
                android:textColor="#8B7CA2"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <ProgressBar
                android:id="@+id/pb_reader_splash"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="160dp"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:progressDrawable="@drawable/bg_splash_progress" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
