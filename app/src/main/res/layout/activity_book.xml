<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <View
        android:id="@+id/ambientGlowView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <com.nightread.app.ui.customlayout.CustomReaderPageView
        android:id="@+id/bookReaderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
    <View
        android:id="@+id/touchInterceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/ivBookCoverPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <View
        android:id="@+id/bookmarkArea"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="top|end"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:visibility="visible" />

    <!-- Dog-ear Bookmark -->
    <ImageView
        android:id="@+id/ivDogEar"
        android:layout_width="18dp"
        android:layout_height="33dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_dog_ear"
        android:scaleType="fitXY"
        android:visibility="gone"
        android:alpha="0.8"
        app:tint="@color/accent"
        android:contentDescription="Bookmark Dog-ear" />

    <LinearLayout
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="220 вольт"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmark" />

        <ImageButton
            android:id="@+id/btnChapters"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmarks_list" />

        <ImageButton
            android:id="@+id/btnNotes"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_note" />

        <ImageButton
            android:id="@+id/btnTts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_headphones"
            android:contentDescription="Озвучивание текста" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings_24dp" />


    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Стр. 10 из 226" />
        
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="2dp"
            android:maxHeight="2dp"
            android:thumbTint="#000000"
            android:progressTint="#000000"
            android:progressBackgroundTint="#CCCCCC" />

        <ImageButton
            android:id="@+id/btnBottomBookmark"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmark"
            android:contentDescription="Закладка" />
    </LinearLayout>

    <View
        android:id="@+id/amberFilterOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <View
        android:id="@+id/extraDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <View
        android:id="@+id/glassyTransitionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        android:alpha="0" />

    <!-- Fullscreen HUD Overlays -->
    <LinearLayout
        android:id="@+id/fullscreenTopHUD"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="36dp"
        android:paddingBottom="12dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:id="@+id/tvFullscreenTimeBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:text="12:00  •  🔋 100%" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fullscreenBottomHUD"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="12dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:id="@+id/tvFullscreenProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:text="Стр. 1 из 100" />

        <ProgressBar
            android:id="@+id/pbFullscreenProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#33CCCCCC"
            android:progressTint="#FFFFFF" />
    </LinearLayout>

    <!-- Accidental Exit Warning -->
    <LinearLayout
        android:id="@+id/accidentalExitWarning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_toast"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:alpha="0"
        android:clickable="false"
        android:focusable="false">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/warning_swipe_to_exit"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Brightness Indicator -->
    <TextView
        android:id="@+id/tvBrightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_brightness"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:visibility="gone"
        android:text="☀ 75%" />

    <!-- Warmth Indicator -->
    <TextView
        android:id="@+id/tvWarmth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_brightness"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:visibility="gone"
        android:text="🌡 30%" />

    <!-- Book Reader Loading / Splash Overlay -->
    <FrameLayout
        android:id="@+id/reader_splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <!-- Starry Background matching the Main Splash Screen -->
        <com.nightread.app.ui.StarryNightView
            android:id="@+id/reader_splash_starry_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_reader_splash_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N I G H T R E A D"
                android:textColor="#FFE3A8"
                android:textSize="20sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.35" />

            <TextView
                android:id="@+id/tv_reader_splash_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="АТМОСФЕРА ПОЛУНОЧИ"
                android:textColor="#8B7CA2"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.25" />

            <TextView
                android:id="@+id/tv_reader_splash_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Настройка ночного уюта..."
                android:textColor="#8B7CA2"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <ProgressBar
                android:id="@+id/pb_reader_splash"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="160dp"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:progressDrawable="@drawable/bg_splash_progress" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
