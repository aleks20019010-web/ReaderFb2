<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="#231735">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cover container taking most of the card height -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="195dp"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <!-- Realistic 3D volume book card skeleton -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#10FFFFFF"
                app:cardBackgroundColor="#1A112B">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#150E24" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- Text container under the cover -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp">

            <!-- Title Line 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="12dp"
                app:cardCornerRadius="6dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2E1E45" />

            <!-- Title Line 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="12dp"
                android:layout_marginTop="5dp"
                app:cardCornerRadius="6dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2E1E45" />

            <!-- Author Line -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="55dp"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="5dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1E1430" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
