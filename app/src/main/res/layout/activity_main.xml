<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- The main content view -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Dynamic Starry Parallax Background -->
        <com.nightread.app.ui.StarryNightView
            android:id="@+id/starry_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:background="@android:color/transparent"
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Liquid Onboarding / Shared Splash Overlay Layer -->
        <FrameLayout
            android:id="@+id/splash_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#05020E"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="28dp">

                <!-- Title/Header of App -->
                <TextView
                    android:id="@+id/tv_splash_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="N I G H T R E A D"
                    android:textColor="#FFE3A8"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="0.35" />

                <TextView
                    android:id="@+id/tv_splash_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="АТМОСФЕРА ПОЛУНОЧИ"
                    android:textColor="#8B7CA2"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.25" />

                <!-- Main Mood Card / Illustration Container -->
                <FrameLayout
                    android:id="@+id/card_mood"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:background="@null"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <!-- Glowing Icon Circle Frame -->
                        <FrameLayout
                            android:id="@+id/layout_glowing_icon"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/bg_circle_dark"
                            android:padding="16dp">

                            <!-- Circle glow overlay behind icon -->
                            <View
                                android:id="@+id/view_icon_glow"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:alpha="0.25"
                                android:background="@drawable/bg_circle_light"
                                android:backgroundTint="#FFE3A8" />

                            <ImageView
                                android:id="@+id/iv_splash_logo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_premium_moon" />
                        </FrameLayout>

                        <!-- Mood Title -->
                        <TextView
                            android:id="@+id/tv_mood_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="28dp"
                            android:text="Золотая Галактика"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.05" />

                        <!-- Theme Tag / Subtitle -->
                        <TextView
                            android:id="@+id/tv_mood_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="ПРЕМИУМ ОФЛАЙН ЧТЕНИЕ"
                            android:textColor="#FFE3A8"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"
                            android:letterSpacing="0.2" />

                        <!-- Atmospheric Quote -->
                        <TextView
                            android:id="@+id/tv_mood_quote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:text="Когда весь мир засыпает, открываются страницы великих тайн. Читайте в идеальной темноте и уюте."
                            android:textColor="#D0C8D8"
                            android:textSize="15sp"
                            android:fontFamily="serif"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.3" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Progress Loading Section -->
                <LinearLayout
                    android:id="@+id/layout_splash_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tv_splash_loading_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Инициализация приложения..."
                        android:textColor="#8B7CA2"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="12dp" />

                    <ProgressBar
                        android:id="@+id/pb_splash_loading"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginLeft="24dp"
                        android:layout_marginRight="24dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_splash_progress" />
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- The navigation drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.NightRead.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
