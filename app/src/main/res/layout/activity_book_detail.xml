<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 1. Scrollable Content (starts from y=0 under the floating transparent toolbar) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Cover container at the very top -->
            <FrameLayout
                android:id="@+id/flCoverContainer"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:background="@android:color/transparent">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:contentDescription="Обложка книги" />

                <TextView
                    android:id="@+id/tvCoverLetter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="#E8D8F0"
                    android:visibility="gone"
                    tools:text="О" />
            </FrameLayout>

            <!-- Text Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <!-- Book Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"
                    android:lineSpacingMultiplier="1.1"
                    tools:text="Орден Архитекторов" />

                <!-- Author Row -->
                <LinearLayout
                    android:id="@+id/llAuthorContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="@color/accent"
                        android:textStyle="bold"
                        tools:text="Олег Сапфир, Юрий Винокуров" />
                </LinearLayout>

                <!-- Series Row (clickable, hidden if none) -->
                <LinearLayout
                    android:id="@+id/llSeriesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tvSeries"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/accent"
                        android:textStyle="italic"
                        tools:text="Серия: Орден Архитекторов №1" />
                </LinearLayout>

                <!-- Invisible / Stub for Compatibility if tvSeriesBanner is still assigned/used -->
                <TextView
                    android:id="@+id/tvSeriesBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <!-- Action Buttons Row (Favorite, Share, Delete) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:id="@+id/ivFavorite"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:contentDescription="Избранное"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:id="@+id/ivWantToRead"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@drawable/ic_pin"
                        android:contentDescription="Хочу прочитать"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:id="@+id/ivShare"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_share"
                        android:contentDescription="Поделиться"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:id="@+id/ivDelete"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_delete"
                        android:contentDescription="Удалить"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Annotation Block -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/CardViewStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:id="@+id/llAnnotationContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:animateLayoutChanges="true">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="АННОТАЦИЯ"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFE3A8"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvAnnotation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:lineSpacingMultiplier="1.2"
                            android:ellipsize="end"
                            android:maxLines="5"
                            tools:text="Я был величайшим Магом Земли в своем мире. Глава целого Ордена. Ордена Архитекторов. Но, чем старше ста..." />

                        <TextView
                            android:id="@+id/tvReadMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="8dp"
                            android:text="...читать далее"
                            android:textColor="@color/accent"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="4dp"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Info Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ИНФОРМАЦИЯ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFE3A8"
                    android:layout_marginBottom="12dp" />

                <!-- Document Info Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/CardViewStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Language Block -->
                        <LinearLayout
                            android:id="@+id/llLanguageContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tvLanguage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                tools:text="Русский" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#B8A0C8"
                                android:text="Язык документа"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider" />

                        <!-- Bookmark and Last Read Block -->
                        <LinearLayout
                            android:id="@+id/llProgressContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tvProgress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                tools:text="63%, 5 июля 2026 г. 11:11" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#B8A0C8"
                                android:text="Текущая закладка и время последнего чтения"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider" />

                        <!-- Format and File Size Block -->
                        <LinearLayout
                            android:id="@+id/llFormatSizeContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tvFormatSize"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                tools:text="FB2, 818 КБ" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#B8A0C8"
                                android:text="Формат и размер файла"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider" />

                        <!-- SHA-1 Identifier Block -->
                        <LinearLayout
                            android:id="@+id/llSha1Container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tvSha1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                tools:text="47fbfb03d54eb3ec97f5053e267c907c322dd51c" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#B8A0C8"
                                android:text="Идентификатор файла документа (SHA-1)"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Copies Files List Section -->
                <TextView
                    android:id="@+id/tvCopiesHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFE3A8"
                    android:text="Копии файла документа"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/llFilesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 2. Floating Toolbar Overlay (Drawn AFTER NestedScrollView so it sits on top) -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/btn_back_with_bg"
            app:navigationIconTint="@null">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReadToolbar"
                style="@style/Widget.Material3.Button.UnelevatedButton"
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:text="ЧИТАТЬ"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
