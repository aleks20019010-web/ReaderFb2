<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1A0D2A"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Header Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvSettingsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Настройки"
                    android:textColor="#E8D8F0"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Закрыть"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#E8D8F0" />
            </RelativeLayout>

            <!-- Divider -->
            <View
                android:id="@+id/dividerTop"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="#3A2A4E" />

            <!-- Color Schemes Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvColorSchemeLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Цветовая схема" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <!-- Light Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeLight"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeLight"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_light" />
                    </FrameLayout>

                    <!-- Sepia Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeSepia"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeSepia"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_sepia" />
                    </FrameLayout>

                    <!-- Dark Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeDark"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeDark"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_dark" />
                    </FrameLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Font Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFontLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Шрифт" />

                <!-- Quick Font Selection Row -->
                <LinearLayout
                    android:id="@+id/layoutFontQuick"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Sans Button -->
                    <TextView
                        android:id="@+id/btnFontSans"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="Sans-Serif"
                        android:fontFamily="sans-serif"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Serif Button -->
                    <TextView
                        android:id="@+id/btnFontSerif"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="Serif"
                        android:fontFamily="serif"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Monospace Button -->
                    <TextView
                        android:id="@+id/btnFontMono"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Monospace"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerFont"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Font Size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvFontSizeLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Размер шрифта" />

                    <TextView
                        android:id="@+id/tvFontSizeValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="16 sp" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarFontSize"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:max="14" />
            </LinearLayout>

            <!-- Font Weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvFontWeightLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Жирность" />

                    <TextView
                        android:id="@+id/tvFontWeightValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Обычный" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarFontWeight"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:max="16" />
            </LinearLayout>

            <!-- Theme Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvThemeLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Тема" />

                <Spinner
                    android:id="@+id/spinnerTheme"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Page Flip Animation Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAnimationLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Анимация листания" />

                <Spinner
                    android:id="@+id/spinnerAnimation"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Line Spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvLineSpacingLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Интервал" />

                    <TextView
                        android:id="@+id/tvLineSpacingValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1.20" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarLineSpacing"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:max="10" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/dividerMiddle"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="6dp"
                android:background="#3A2A4E" />

            <!-- Auto-Discovery Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchAutoDiscovery"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAutoDiscoveryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Авто-обнаружение"
                        android:textColor="#E8D8F0"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAutoDiscoveryDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Поиск fb2 в фоне"
                        android:textColor="#B8A0C8"
                        android:textSize="10sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoDiscovery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>
