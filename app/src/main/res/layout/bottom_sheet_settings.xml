<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#F5F0F8"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="false">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="64dp">

            <!-- Header Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvSettingsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Настройки"
                    android:textColor="#E8D8F0"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Закрыть"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#E8D8F0" />
            </RelativeLayout>

            <!-- Divider -->
            <View
                android:id="@+id/dividerTop"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#D2C5E3" />

            <!-- Bedtime Mode Quick Action Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBedtimeMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#EAE2F3"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙"
                        android:textSize="24sp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBedtimeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bedtime_mode_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBedtimeDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bedtime_mode_desc"
                            android:textColor="#D1C4E9"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Color Schemes Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvColorSchemeLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Цветовая схема" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <!-- Light Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeLight"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeLight"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_light" />
                    </FrameLayout>

                    <!-- Sepia Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeSepia"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeSepia"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_sepia" />
                    </FrameLayout>

                    <!-- Dark Theme Button -->
                    <FrameLayout
                        android:id="@+id/btnThemeDark"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless">

                        <View
                            android:id="@+id/ringThemeDark"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_selection_ring" />

                        <View
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_dark" />
                    </FrameLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Font Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFontLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Шрифт" />

                <!-- Quick Font Selection Row -->
                <LinearLayout
                    android:id="@+id/layoutFontQuick"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Sans Button -->
                    <TextView
                        android:id="@+id/btnFontSans"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="Sans-Serif"
                        android:fontFamily="sans-serif"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Serif Button -->
                    <TextView
                        android:id="@+id/btnFontSerif"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="Serif"
                        android:fontFamily="serif"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Monospace Button -->
                    <TextView
                        android:id="@+id/btnFontMono"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Monospace"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerFont"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Theme Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvThemeLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Тема" />

                <Spinner
                    android:id="@+id/spinnerTheme"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Page Flip Animation Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAnimationLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Анимация листания" />

                <Spinner
                    android:id="@+id/spinnerAnimation"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>

            <!-- Text Alignment Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAlignmentLabel"
                    style="@style/SettingsLabelStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Выравнивание текста" />

                <Spinner
                    android:id="@+id/spinnerAlignment"
                    style="@style/CompactSpinnerStyle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/spinner_dropdown_bg" />
            </LinearLayout>



            <!-- Divider -->
            <View
                android:id="@+id/dividerMiddle"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#D2C5E3" />

            <!-- Font Size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvFontSizeLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Размер шрифта" />

                    <TextView
                        android:id="@+id/tvFontSizeValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="16 sp" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarFontSize"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="14" />
            </LinearLayout>

            <!-- Font Weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvFontWeightLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Жирность" />

                    <TextView
                        android:id="@+id/tvFontWeightValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Обычный" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarFontWeight"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="16" />
            </LinearLayout>

            <!-- Line Spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvLineSpacingLabel"
                        style="@style/SettingsLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="Межстрочный интервал" />

                    <TextView
                        android:id="@+id/tvLineSpacingValue"
                        style="@style/SettingsValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1.2" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarLineSpacing"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="10" />
            </LinearLayout>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchAutoDiscovery"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAutoDiscoveryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Авто-обнаружение"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAutoDiscoveryDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Поиск книг в фоне"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoDiscovery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Auto-Light-Night Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchAutoLightNight"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAutoLightNightTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_light_night_title"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAutoLightNightDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_light_night_desc"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoLightNight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Amber Eye Care Filter Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchAmberFilter"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAmberFilterTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/amber_filter_title"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAmberFilterDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/amber_filter_desc"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAmberFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Amber Filter Intensity SeekBar -->
            <LinearLayout
                android:id="@+id/layoutAmberIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvAmberIntensityLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="@string/amber_filter_intensity"
                        android:textColor="#B8A0C8"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvAmberIntensityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textColor="#E8D8F0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="30%" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarAmberIntensity"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="100" />
            </LinearLayout>

            <!-- Extra Dim Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchExtraDim"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvExtraDimTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/extra_dim_title"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvExtraDimDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/extra_dim_desc"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchExtraDim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Extra Dim Intensity SeekBar -->
            <LinearLayout
                android:id="@+id/layoutExtraDimIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvExtraDimIntensityLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="@string/extra_dim_intensity"
                        android:textColor="#B8A0C8"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvExtraDimIntensityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textColor="#E8D8F0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="40%" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarExtraDimIntensity"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="90" />
            </LinearLayout>

            <!-- Sleep Timer Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchSleepTimer"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSleepTimerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sleep_timer_title"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSleepTimerDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sleep_timer_desc"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSleepTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Sleep Timer Duration SeekBar -->
            <LinearLayout
                android:id="@+id/layoutSleepTimerDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvSleepTimerDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="@string/sleep_timer_duration"
                        android:textColor="#B8A0C8"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvSleepTimerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textColor="#E8D8F0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="30 мин" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarSleepTimer"
                    style="@style/CompactSeekBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:max="120" />
            </LinearLayout>

            <!-- Shake to Extend Switch -->
            <RelativeLayout
                android:id="@+id/layoutShakeToExtend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchShakeToExtend"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvShakeToExtendTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shake_to_extend_title"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvShakeToExtendDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shake_to_extend_desc"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShakeToExtend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#D2C5E3" />

            <!-- Haptic Feedback Switch Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchHapticFeedback"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHapticFeedbackTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Тактильный отклик (Haptic)"
                        android:textColor="#E8D8F0"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHapticFeedbackDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Приятные микровибрации при листании и действиях"
                        android:textColor="#B8A0C8"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchHapticFeedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/white"
                    app:trackTint="#9B59B6" />
            </RelativeLayout>



        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>
