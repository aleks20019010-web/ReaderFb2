<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_gradient"
    android:animateLayoutChanges="true">

    <!-- Top Action Bar Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_panel"
        android:padding="16dp"
        android:elevation="4dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Меню"
                android:tint="@color/icon_tint"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Библиотека"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipToPadding="false">

            <!-- Expandable SearchView (Initially Hidden) -->
            <androidx.appcompat.widget.SearchView
                android:id="@+id/etSearch"
                android:layout_width="180dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search_input"
                android:visibility="gone"
                android:elevation="2dp"
                app:iconifiedByDefault="false"
                app:queryHint="Поиск..."
                app:searchIcon="@null"
                app:queryBackground="@null"
                app:submitBackground="@null" />

            <!-- Toggle Grid/List View Mode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleViewMode"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_custom_list"
                app:iconTint="#3D2C1A"
                app:backgroundTint="#EDE5D8"
                app:cornerRadius="24dp"
                app:elevation="2dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:contentDescription="Режим списка" />

            <!-- Search Toggle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchToggle"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_custom_search"
                app:iconTint="#3D2C1A"
                app:backgroundTint="#EDE5D8"
                app:cornerRadius="24dp"
                app:elevation="2dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:contentDescription="Поиск" />

            <!-- Manual Import -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImport"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_custom_import"
                app:iconTint="#3D2C1A"
                app:backgroundTint="#EDE5D8"
                app:cornerRadius="24dp"
                app:elevation="2dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:contentDescription="Импорт" />

            <!-- Auto Scan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAutoScan"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_custom_scan"
                app:iconTint="#FFFFFF"
                app:backgroundTint="#C4956A"
                app:cornerRadius="24dp"
                app:elevation="4dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:contentDescription="Автосканирование" />

        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Scan Progress Status Container -->
        <include layout="@layout/scan_status_layout" />

        <!-- Continue Reading Section -->
        <LinearLayout
            android:id="@+id/layoutContinueReading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Продолжить чтение"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContinueReading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>

        <!-- FrameLayout for list and placeholder -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- SwipeRefreshLayout for manual rescan -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- RecyclerView Grid of Books -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBooks"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="vertical" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!-- Beautiful Empty library placeholder state with illustration and call to action -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivEmptyIllustration"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_empty_library"
                    android:contentDescription="Иллюстрация пустой библиотеки"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvEmptyStateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ваша библиотека пуста"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvEmptyStateDesc"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:text="Сканируйте память устройства, чтобы автоматически найти книги в форматах FB2, EPUB и TXT."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1"
                    android:layout_marginBottom="24dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmptyStateScan"
                    style="@style/ButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_custom_scan"
                    app:iconTint="#FFFFFF"
                    android:text="Запустить сканирование"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#C4956A"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
