<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSettings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Top Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:titleTextColor="#E8D8F0"
        app:navigationIconTint="#E8D8F0"
        app:title="@string/drawer_settings" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ================= ЯЗЫК ИНТЕРФЕЙСА ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_section_language"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Language Selector (Spinner) -->
            <LinearLayout
                android:id="@+id/layoutLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_language_title"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_language_desc"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A1A3E"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- ================= СИНХРОНИЗАЦИЯ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_section_sync"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Switch Auto-Sync -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/switchAutoSync"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tvAutoSyncLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_auto_sync"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_auto_sync_desc"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Sync Period Selector (Spinner) -->
            <LinearLayout
                android:id="@+id/layoutSyncPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_sync_period"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_sync_period_desc"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerSyncPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A1A3E"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Sync Start Time Picker Button -->
            <RelativeLayout
                android:id="@+id/layoutSyncTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/tvSyncTimeValue"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_sync_time"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_sync_time_desc"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSyncTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="03:00"
                    android:textColor="#E8D8F0"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ================= НАСТРОЙКИ БИБЛИОТЕКИ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_section_library"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Scan library -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanLibrary"
                style="@style/ButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/settings_scan_library"
                app:icon="@drawable/ic_custom_scan"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <!-- Manual Import -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManualImport"
                style="@style/ButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/settings_manual_import"
                app:icon="@drawable/ic_custom_import"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <!-- Find & Delete Duplicates -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteDuplicates"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:textColor="#E8D8F0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/settings_delete_duplicates"
                app:strokeColor="#4DFFFFFF"
                app:rippleColor="#26FFFFFF"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:iconTint="#E8D8F0" />

            <!-- ================= ОЧИСТКА И ВОССТАНОВЛЕНИЕ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_section_cleanup"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Reset Cache -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetCache"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:textColor="#E8D8F0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/settings_reset_cache"
                app:strokeColor="#4DFFFFFF"
                app:rippleColor="#26FFFFFF"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/stat_notify_sync"
                app:iconGravity="textStart"
                app:iconTint="#E8D8F0" />

            <!-- Clear Library -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearLibrary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:textColor="#E8D8F0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/settings_clear_library"
                app:strokeColor="#4DFFFFFF"
                app:rippleColor="#26FFFFFF"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                app:iconTint="#E8D8F0" />

            <!-- Info -->
            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Версия: 1.0"
                android:textColor="#887C9E"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
