<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSettings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Top Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:titleTextColor="#E8D8F0"
        app:title="Настройки" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ================= СИНХРОНИЗАЦИЯ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="СИНХРОНИЗАЦИЯ"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Switch Auto-Sync -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/switchAutoSync"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tvAutoSyncLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Авто-синхронизация"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Синхронизация книг в фоновом режиме"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Sync Period Selector (Spinner) -->
            <LinearLayout
                android:id="@+id/layoutSyncPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Период авто-синхронизации"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Как часто запускать фоновую синхронизацию"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerSyncPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Sync Start Time Picker Button -->
            <RelativeLayout
                android:id="@+id/layoutSyncTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/tvSyncTimeValue"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Время запуска"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Предпочтительное время запуска (ночью)"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSyncTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="03:00"
                    android:textColor="#E8D8F0"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ================= ТЕМЫ И ОФОРМЛЕНИЕ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="ТЕМЫ И ОФОРМЛЕНИЕ"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Auto-Theme Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:id="@+id/tvAutoThemeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Авто-тема"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Choose Theme (Spinner) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:id="@+id/tvThemeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Выберите тему"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerThemeSelect"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- ================= НАСТРОЙКИ БИБЛИОТЕКИ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="НАСТРОЙКИ БИБЛИОТЕКИ"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Show All Formats Switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp"
                android:padding="12dp"
                android:background="@drawable/bg_glass_panel">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/switchShowAllFormats"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tvShowAllFormatsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Показывать все форматы"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvShowAllFormatsDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Отображать в библиотеке EPUB, MOBI, PDF, DJVU и другие форматы"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowAllFormats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Scan library -->
            <Button
                android:id="@+id/btnScanLibrary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#6200EE"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Сканировать библиотеку" />

            <!-- Manual Import -->
            <Button
                android:id="@+id/btnManualImport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#3700B3"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Ручной импорт" />

            <!-- Find & Delete Duplicates -->
            <Button
                android:id="@+id/btnDeleteDuplicates"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#018786"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Найти и удалить дубликаты книг" />

            <!-- ================= ОЧИСТКА И ВОССТАНОВЛЕНИЕ ================= -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="ОЧИСТКА И ВОССТАНОВЛЕНИЕ"
                android:textColor="#B0A4C4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Reset Cache -->
            <Button
                android:id="@+id/btnResetCache"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Сбросить кэш сканирования" />

            <!-- Clear Library -->
            <Button
                android:id="@+id/btnClearLibrary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#E91E63"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Очистить библиотеку" />

            <!-- Info -->
            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Версия: 1.0"
                android:textColor="#887C9E"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
