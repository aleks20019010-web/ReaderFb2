<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:background="@drawable/bg_dark_purple_bottom_sheet">

    <!-- Drag handle in M3 style -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#4D9B59B6" />

    <TextView
        android:id="@+id/tvSelectedWord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#9B59B6"
        android:text="Выбранное слово" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3A2A4E"
        android:layout_marginBottom="8dp" />



    <!-- Find in Book option -->
    <LinearLayout
        android:id="@+id/btnFind"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_custom_search"
            android:contentDescription="Найти в книге"
            app:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Найти в книге"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Copy option -->
    <LinearLayout
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_word_copy"
            android:contentDescription="Копировать"
            app:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Копировать"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Explain with AI option -->
    <LinearLayout
        android:id="@+id/btnExplain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_word_explain"
            android:contentDescription="Объяснить ИИ"
            app:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Объяснить значение (ИИ)"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Translate with AI option -->
    <LinearLayout
        android:id="@+id/btnTranslate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_word_translate"
            android:contentDescription="Перевести ИИ"
            app:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Перевести (ИИ)"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Create Note option -->
    <LinearLayout
        android:id="@+id/btnCreateNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_note"
            android:contentDescription="Добавить заметку"
            app:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Добавить заметку"
            android:textSize="16sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Note Input Container -->
    <LinearLayout
        android:id="@+id/layoutNoteInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A2A4E"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ваша заметка к тексту:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#9B59B6"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top|start"
            android:background="@drawable/bg_edittext_rounded"
            android:padding="12dp"
            android:hint="Текст заметки..."
            android:textColor="@color/text_primary"
            android:textColorHint="#6B5980"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSaveNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сохранить заметку"
            android:backgroundTint="#9B59B6"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- AI Response Container -->
    <LinearLayout
        android:id="@+id/layoutAiResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A2A4E"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ответ ИИ-ассистента:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#9B59B6"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pbAiLoading"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_horizontal"
            android:layout_margin="12dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />
    </LinearLayout>

</LinearLayout>
