<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:background="@drawable/bg_dark_purple_bottom_sheet">

    <!-- Drag handle in M3 style -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#4D9B59B6" />

    <TextView
        android:id="@+id/tvSelectedWord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="24dp"
        android:text="Слово"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:maxLines="3"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="16dp">
        
        <LinearLayout
            android:id="@+id/btnCopy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_word_copy"
                app:tint="@color/accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Копия"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>
        
        <LinearLayout
            android:id="@+id/btnFind"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_custom_search"
                app:tint="@color/accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Найти"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>
        
        <LinearLayout
            android:id="@+id/btnCreateNote"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_note"
                app:tint="@color/accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Заметка"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </LinearLayout>
    
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3A2A4E"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="✨ ИИ-Помощник (Llama 3.2)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:layout_marginBottom="12dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <Button
                android:id="@+id/btnAiExplain"
                style="@style/Widget.Material3.Button.TonalButton" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Толкование"
                android:layout_marginEnd="8dp" />
                
            <Button
                android:id="@+id/btnAiTranslate"
                style="@style/Widget.Material3.Button.TonalButton" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Перевод"
                android:layout_marginEnd="8dp" />
                
            <Button
                android:id="@+id/btnAiSummarize"
                style="@style/Widget.Material3.Button.TonalButton" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Краткий пересказ"
                android:layout_marginEnd="8dp" />
                
            <Button
                android:id="@+id/btnAiCharacter"
                style="@style/Widget.Material3.Button.TonalButton" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Кто это?"
                android:layout_marginEnd="8dp" />
                
            <Button
                android:id="@+id/btnAiSimplify"
                style="@style/Widget.Material3.Button.TonalButton" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Упростить текст" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Note Input Container -->
    <LinearLayout
        android:id="@+id/layoutNoteInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ваша заметка к тексту:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top|start"
            android:background="@drawable/bg_edittext_rounded"
            android:padding="12dp"
            android:hint="Текст заметки..."
            android:textColor="@color/text_primary"
            android:textColorHint="#6B5980"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSaveNote"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сохранить заметку"
            android:backgroundTint="@color/btn_bg"
            android:textColor="@color/btn_text" />
    </LinearLayout>

    <!-- AI Response Container -->
    <LinearLayout
        android:id="@+id/layoutAiResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">

        <ProgressBar
            android:id="@+id/pbAiLoading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_margin="12dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            
            <TextView
                android:id="@+id/tvAiResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:textIsSelectable="true" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
