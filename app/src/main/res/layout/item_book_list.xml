<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="5dp"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.card.MaterialCardView
        style="@style/CardViewStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardUseCompatPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:foreground="?android:attr/selectableItemBackground">

            <!-- Cover image on the left: padded to allow glow to bleed out, with 3D volume book appearance -->
            <FrameLayout
                android:layout_width="106dp"
                android:layout_height="136dp"
                android:layout_marginEnd="12dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingHorizontal="10dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">

                <!-- Deep Glow: blurred background glow that automatically matches cover's color -->
                <View
                    android:id="@+id/vCoverGlow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@android:color/transparent" />

                <!-- Realistic 3D volume book card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvBookCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0.5dp"
                    app:strokeColor="#25FFFFFF"
                    app:cardBackgroundColor="#1A1A2E"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Gradient background (fallback) -->
                        <View
                            android:id="@+id/vCoverBackground"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#e94560" />

                        <ImageView
                            android:id="@+id/ivCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="Обложка книги" />

                        <!-- Cover letter fallback when no image exists -->
                        <TextView
                            android:id="@+id/tvCoverLetter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <!-- Book spine crease 3D overlay -->
                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="start"
                            android:background="@drawable/bg_book_spine" />

                        <!-- Book page-edge highlight on right -->
                        <View
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="end"
                            android:background="#20FFFFFF" />

                        <!-- Progress bar at the bottom of the cover -->
                        <ProgressBar
                            android:id="@+id/pbReadingProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_gravity="bottom"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="@color/accent"
                            android:progressBackgroundTint="#20FFFFFF"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Book details on the right -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <!-- Book Title: dynamic color, size 16sp, bold, max 2 lines -->
                <TextView
                    android:id="@+id/tvBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp" />

                <!-- Book Author: dynamic color, size 14sp, max 1 line -->
                <TextView
                    android:id="@+id/tvBookAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp" />

                <!-- Book Annotation: dynamic color, size 13sp, max 3 lines with ellipsize -->
                <TextView
                    android:id="@+id/tvBookAnnotation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />

                <!-- Book Series: hidden but present to avoid binding issues -->
                <TextView
                    android:id="@+id/tvBookSeries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Dummy/hidden delete button to keep logic happy -->
            <View
                android:id="@+id/btnDelete"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
