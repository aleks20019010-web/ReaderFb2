<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/bg_panel</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">#05020E</item>
        <item name="android:windowBackground">#05020E</item>
        
        <!-- Splash Screen customization for API 31+ to avoid showing launcher icon before greeting screen -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">#05020E</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_panel</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Customized shape appearances for tactile/rounded design -->
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.App.Medium</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.App.Large</item>
        
        <!-- Button Style -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>

        <!-- Status Bar and Navigation Bar Colors for Purple Fog Theme -->
        <item name="android:statusBarColor">@color/bg_gradient_start</item>
        <item name="android:navigationBarColor">@color/bg_gradient_end</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <item name="colorControlHighlight">#4D9B59B6</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="alertDialogTheme">@style/Theme.NightRead.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.NightRead.Dialog</item>
        <item name="android:spinnerItemStyle">@style/NightReadSpinnerItem</item>
        <item name="android:spinnerDropDownItemStyle">@style/NightReadSpinnerDropdown</item>

    </style>

    <style name="Theme.NightRead" parent="Theme.MyApplication" />

    <style name="Theme.NightRead.Dialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/starry_bg_simple</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_sync_primary</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_sync_primary</item>
        <item name="android:textColorSecondary">@color/text_sync_secondary</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Theme.NightRead.PopupMenu" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#E5D9F4</item>
        <item name="colorSurface">#1D0E30</item>
        <item name="android:colorBackground">#1D0E30</item>
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>

    <style name="Theme.NightRead.BottomSheet" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/Widget.NightRead.BottomSheet</item>
    </style>

    <style name="Widget.NightRead.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.Large</item>
    </style>

    <style name="ShapeAppearance.App.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">12dp</item>
        <item name="colorControlHighlight">#4D9B59B6</item>
    </style>

    <style name="ShapeAppearance.App.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">20dp</item>
        <item name="colorControlHighlight">#4D9B59B6</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/btn_bg</item>
        <item name="android:textColor">@color/btn_text</item>
        <item name="cornerRadius">12dp</item>
        <item name="colorControlHighlight">#4D9B59B6</item>
    </style>
</resources>
