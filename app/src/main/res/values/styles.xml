<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- CardView Style with 16dp corner radius and 12dp elevation for Purple Fog Theme -->
    <style name="CardViewStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">12dp</item>
    </style>

    <!-- Button Style with push down effect -->
    <style name="ButtonStyle" parent="Widget.Material3.Button.ElevatedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@animator/button_press_animator</item>
        <item name="backgroundTint">@color/btn_bg</item>
        <item name="android:textColor">@color/btn_text</item>
    </style>

    <!-- SeekBar Style for Purple Fog Theme -->
    <style name="SeekBarStyle" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">@color/accent</item>
        <item name="android:thumbTint">@color/accent</item>
    </style>

    <!-- Switch Style for Purple Fog Theme -->
    <style name="SwitchStyle" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="trackTint">@color/accent</item>
        <item name="thumbTint">@color/white</item>
    </style>

    <!-- Animation style for Settings dialog -->
    <style name="SettingsDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/enter_from_top_right</item>
        <item name="android:windowExitAnimation">@anim/exit_to_top_right</item>
    </style>

    <!-- Style for the Dialog window itself -->
    <style name="SettingsDialogStyle" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.15</item>
    </style>

    <!-- Style for settings section headings/labels (compact) -->
    <style name="SettingsLabelStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#B8A0C8</item> <!-- text_secondary -->
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <!-- Style for text values (compact) -->
    <style name="SettingsValueStyle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#E8D8F0</item> <!-- text_primary -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Compact Spinner Style -->
    <style name="CompactSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:backgroundTint">#9B59B6</item> <!-- accent -->
        <item name="android:padding">4dp</item>
    </style>

    <!-- Compact SeekBar Style -->
    <style name="CompactSeekBarStyle" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">#9B59B6</item>
        <item name="android:thumbTint">#9B59B6</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
    </style>

    <style name="NightReadSpinnerItem" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">#E8D8F0</item>
        <item name="android:background">#2A1A3E</item>
    </style>
    
    <style name="NightReadSpinnerDropdown" parent="Widget.AppCompat.Spinner.DropDown">
        <item name="android:popupBackground">#2A1A3E</item>
    </style>

    <!-- Dark Purple Bottom Sheet Style -->
    <style name="DarkPurpleBottomSheetDialog" parent="Theme.Design.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/DarkPurpleBottomSheetStyle</item>
    </style>

    <style name="DarkPurpleBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Style for header icon buttons without background -->
    <style name="HeaderIconButtonStyle" parent="Widget.Material3.Button.IconButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="elevation">0dp</item>
        <item name="iconSize">20dp</item>
        <item name="iconTint">@color/icon_tint</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

</resources>
