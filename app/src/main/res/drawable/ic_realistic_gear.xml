<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="36dp"
    android:height="36dp"
    android:viewportWidth="36"
    android:viewportHeight="36">

    <!-- Clip path to create a clean, 100% transparent hole in the center (radius 4.0 at 18,18) -->
    <clip-path
        android:pathData="M 0,0 H 36 V 36 H 0 Z M 18,14 A 4,4 0 1,0 18,22 A 4,4 0 1,0 18,14 Z" />

    <!-- 1. SHADOW LAYER (Offset slightly down-right for realistic depth) -->
    <group
        android:translateX="0.6"
        android:translateY="1.2">
        
        <!-- Shadow Base Circle -->
        <path
            android:fillColor="#3D000000"
            android:pathData="M 18,5.5 C 24.9,5.5 30.5,11.1 30.5,18 C 30.5,24.9 24.9,30.5 18,30.5 C 11.1,30.5 5.5,24.9 5.5,18 C 5.5,11.1 11.1,5.5 18,5.5 Z" />
            
        <!-- Shadow Teeth (12 symmetric teeth) -->
        <group android:pivotX="18" android:pivotY="18" android:rotation="0"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="30"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="60"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="90"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="120"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="150"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="180"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="210"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="240"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="270"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="300"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
        <group android:pivotX="18" android:pivotY="18" android:rotation="330"><path android:fillColor="#3D000000" android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z" /></group>
    </group>

    <!-- 2. FOREGROUND REALISTIC METALLIC GEAR -->
    <!-- Connect all bases of the teeth with a solid circle -->
    <path
        android:pathData="M 18,5.5 C 24.9,5.5 30.5,11.1 30.5,18 C 30.5,24.9 24.9,30.5 18,30.5 C 11.1,30.5 5.5,24.9 5.5,18 C 5.5,11.1 11.1,5.5 18,5.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="1"
                android:endX="18"
                android:endY="35"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFEBD2B4" /> <!-- light warm bronze/gold -->
                <item android:offset="0.5" android:color="#FFD4A87A" /> <!-- medium golden bronze -->
                <item android:offset="1.0" android:color="#FF8C5B34" /> <!-- dark copper/bronze -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 12 Symmetric Teeth filled with bronze-gold gradient -->
    <group android:pivotX="18" android:pivotY="18" android:rotation="0">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFD4A87A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="30">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFC4956A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="60">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFB8855A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="90">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFD4A87A" /><item android:offset="1.0" android:color="#FF9E6F45" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="120">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFC4956A" /><item android:offset="1.0" android:color="#FF8C5B34" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="150">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFB8855A" /><item android:offset="1.0" android:color="#FF7A4E2C" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="180">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFB8855A" /><item android:offset="1.0" android:color="#FF7A4E2C" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="210">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFC4956A" /><item android:offset="1.0" android:color="#FF8C5B34" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="240">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFD4A87A" /><item android:offset="1.0" android:color="#FF9E6F45" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="270">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFB8855A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="300">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFC4956A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
    <group android:pivotX="18" android:pivotY="18" android:rotation="330">
        <path android:pathData="M 15.5,5.5 L 16.75,1 L 19.25,1 L 20.5,5.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:startX="18" android:startY="1" android:endX="18" android:endY="5.5" android:type="linear">
                    <item android:offset="0.0" android:color="#FFEBD2B4" /><item android:offset="1.0" android:color="#FFD4A87A" />
                </gradient>
            </aapt:attr>
        </path>
    </group>

    <!-- Bevel inner layer to add 3D depth inside the teeth connection line -->
    <path
        android:pathData="M18,7.5 C23.247,7.5 27.5,11.753 27.5,17 C27.5,22.247 23.247,26.5 18,26.5 C12.753,26.5 8.5,22.247 8.5,17 C8.5,11.753 12.753,7.5 18,7.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="7.5"
                android:endX="18"
                android:endY="26.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFEBD2B4" />
                <item android:offset="0.5" android:color="#FFD4A87A" />
                <item android:offset="1.0" android:color="#FF9E6F45" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Concentric Ring Recess (carved groove for authentic metal machinery feel) -->
    <path
        android:pathData="M18,9.5 C22.142,9.5 25.5,12.858 25.5,17 C25.5,21.142 22.142,24.5 18,24.5 C13.858,24.5 10.5,21.142 10.5,17 C10.5,12.858 13.858,9.5 18,9.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="9.5"
                android:endX="18"
                android:endY="24.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF5C381E" /> <!-- Deep cavity shadow -->
                <item android:offset="0.5" android:color="#FFAC7F59" />
                <item android:offset="1.0" android:color="#FFEBD2B4" /> <!-- Reflection -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Raised Inner Hub Ring -->
    <path
        android:pathData="M18,12 C20.761,12 23,14.239 23,17 C23,19.761 20.761,22 18,22 C15.239,22 13,19.761 13,17 C13,14.239 15.239,12 18,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="12"
                android:endX="18"
                android:endY="22"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFEBD2B4" />
                <item android:offset="0.4" android:color="#FFD4A87A" />
                <item android:offset="1.0" android:color="#FF7A4E2C" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Hub Inner Shadow Ring around center hole -->
    <path
        android:pathData="M18,13.5 C20.485,13.5 22.5,15.515 22.5,18 C22.5,20.485 20.485,22.5 18,22.5 C15.515,22.5 13.5,20.485 13.5,18 C13.5,15.515 15.515,13.5 18,13.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="13.5"
                android:endX="18"
                android:endY="22.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF4D2F18" /> <!-- Deep shadow around center hole -->
                <item android:offset="1.0" android:color="#FFA67B57" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
