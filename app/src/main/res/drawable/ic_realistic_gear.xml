    <path
        android:pathData="M18,13 C20.209,13 22,14.791 22,17 C22,19.209 20.209,21 18,21 C15.791,21 14,19.209 14,17 C14,14.791 15.791,13 18,13 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="13"
                android:endX="18"
                android:endY="21"
                android:type="linear">
