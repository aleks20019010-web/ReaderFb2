            <gradient
                android:startX="18"
                android:startY="12"
                android:endX="18"
                android:endY="22"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD4A87A" />
                <item android:offset="0.5" android:color="#FFC4956A" />
                <item android:offset="1.0" android:color="#FF7A4E2C" />
            </gradient>
        </aapt:attr>
    </path>

