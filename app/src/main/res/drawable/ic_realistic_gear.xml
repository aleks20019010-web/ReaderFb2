    <path
        android:pathData="M18,9.5 C22.142,9.5 25.5,12.858 25.5,17 C25.5,21.142 22.142,24.5 18,24.5 C13.858,24.5 10.5,21.142 10.5,17 C10.5,12.858 13.858,9.5 18,9.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="9.5"
                android:endX="18"
                android:endY="24.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF633E20" /> <!-- deep cavity shadow -->
                <item android:offset="0.5" android:color="#FFAC7F59" />
                <item android:offset="1.0" android:color="#FFEAD2B5" /> <!-- bright reflection -->
